# Runtime
CONTAINER_ENGINE=podman

# Data path (created by install.sh)
DATA_DIR=$HOME/.ente-docker

# Ente API exposure
ENTE_BIND_ADDRESS=127.0.0.1
ENTE_PORT=8080
ENTE_PUBLIC_URL=http://localhost:8080
ENTE_LOG_LEVEL=info

# PostgreSQL
POSTGRES_DB=ente_db
POSTGRES_USER=ente
POSTGRES_PASSWORD=change_me

# MinIO
MINIO_ROOT_USER=ente_s3
MINIO_ROOT_PASSWORD=change_me
MINIO_BUCKET=ente
S3_REGION=us-east-1

# MinIO web console (optional)
MINIO_CONSOLE_ENABLE=no
MINIO_CONSOLE_PORT=9001

# Ente secrets
ENTE_APP_SECRET=change_me
ENTE_JWT_SECRET=change_me
